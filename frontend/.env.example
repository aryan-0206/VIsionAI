# VisionAI – Frontend Environment Variables
# Copy this to .env.local for local dev (no changes needed locally)
# On Vercel: set VITE_API_URL to your ngrok tunnel URL

# Your ngrok tunnel URL (get this from running: ngrok http 5000)
# Example: VITE_API_URL=https://abc123.ngrok-free.app
VITE_API_URL=http://localhost:5000
