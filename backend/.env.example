# VisionAI Backend — Local Environment Variables
# Copy this file to .env and fill in your values
# This file is loaded automatically when you run: python app.py

# ── ngrok auto-tunnel ─────────────────────────────────────────────────────────
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Optional: set a free static domain so the Vercel URL never changes.
# Get one at: https://dashboard.ngrok.com/cloud-edge/domains  (click "New Domain")
# NGROK_DOMAIN=your-static-domain.ngrok-free.app

# ── Camera settings ───────────────────────────────────────────────────────────
# CAMERA_INDEX=0
# CAMERA_WIDTH=1280
# CAMERA_HEIGHT=720

# ── Model settings ────────────────────────────────────────────────────────────
# YOLO_MODEL=../models/yolov8n.onnx
